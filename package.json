{
  "name": "seanwesleysmith.com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:swedish-teacher": "cd apps/swedish-teacher && bun src/dev.ts",
    "typecheck": "tsc -p apps/swedish-teacher/tsconfig.json --noEmit",
    "build": "rm -rf dist && bun run typecheck && bun scripts/build-sites.ts",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "lucide-react": "^1.20.0",
    "openai": "^6.43.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
